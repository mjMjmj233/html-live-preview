{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "node ./node_modules/typescript/bin/tsc -p ./",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "watch",
      "type": "shell",
      "command": "node ./node_modules/typescript/bin/tsc -watch -p ./",
      "group": "build",
      "isBackground": true,
      "problemMatcher": ["$tsc-watch"]
    }
  ]
}